{
  "manifest_version": 3,
  "name": "TikTok Auto Unfollow",
  "version": "2.0",
  "description": "Automatically unfollow users on TikTok",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://www.tiktok.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TikTok Auto Unfollow"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      }
    }
  }
}